function mp4_to_gif() {
    # Usage:
    # gifextract input.mp4 START_MIN START_SEC END_MIN END_SEC output.gif

    local input="$1"
    local start_min="$2"
    local start_sec="$3"
    local end_min="$4"
    local end_sec="$5"
    local output="${6:-output.gif}"

    if [[ -z "$input" || -z "$start_min" || -z "$start_sec" || -z "$end_min" || -z "$end_sec" ]]; then
        echo "Usage: mp4_to_gif input.mp4 START_MIN START_SEC END_MIN END_SEC [output.gif]"
        return 1
    fi

    local start_time=$((start_min * 60 + start_sec))
    local end_time=$((end_min * 60 + end_sec))
    local duration=$((end_time - start_time))

    if (( duration <= 0 )); then
        echo "Error: end time must be after start time"
        return 1
    fi

    local palette
    palette="$(mktemp /tmp/mp4_to_gif_palette.XXXXXX.png)"

    ffmpeg -y \
        -ss "$start_time" \
        -t "$duration" \
        -i "$input" \
        -vf "fps=15,scale=800:-1:flags=lanczos,palettegen" \
        "$palette"

    ffmpeg -y \
        -ss "$start_time" \
        -t "$duration" \
        -i "$input" \
        -i "$palette" \
        -lavfi "fps=15,scale=800:-1:flags=lanczos[x];[x][1:v]paletteuse" \
        "$output"

    rm -f "$palette"
}