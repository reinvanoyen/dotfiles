function batch_gifs() {
  local listfile="$1"

  if [ -z "$listfile" ] || [ ! -f "$listfile" ]; then
    echo "Usage: batch_gifs gifs.txt"
    return 1
  fi

  local line_no=0

  while IFS= read -r line || [ -n "$line" ]; do
    line_no=$((line_no + 1))

    # Remove Windows carriage return
    line="${line%$'\r'}"

    # Skip empty lines/comments
    [ -z "$line" ] && continue
    [[ "$line" == \#* ]] && continue

    IFS=$'\t' read -r input start_min start_sec end_min end_sec text output <<< "$line"

    if [ -z "$input" ] || [ -z "$start_min" ] || [ -z "$start_sec" ] || \
       [ -z "$end_min" ] || [ -z "$end_sec" ] || [ -z "$text" ] || [ -z "$output" ]; then
      echo "Skipping line $line_no: missing fields"
      echo "$line"
      continue
    fi

    if [ ! -f "$input" ]; then
      echo "Skipping line $line_no: input file not found: $input"
      continue
    fi

    local temp_gif
    temp_gif="$(mktemp "/tmp/batchgif_${line_no}_XXXXXX.gif")"

    echo "Line $line_no:"
    echo "  input:  $input"
    echo "  time:   $start_min:$start_sec -> $end_min:$end_sec"
    echo "  text:   $text"
    echo "  output: $output"

    mp4_to_gif "$input" "$start_min" "$start_sec" "$end_min" "$end_sec" "$temp_gif" || {
      echo "Failed creating base GIF on line $line_no"
      rm -f "$temp_gif"
      continue
    }

    text_on_gif "$temp_gif" "$text" "$output" || {
      echo "Failed adding text on line $line_no"
      rm -f "$temp_gif"
      continue
    }

    rm -f "$temp_gif"
    echo "Done: $output"
  done < "$listfile"
}