function batch_gifs() {
  local listfile="$1"

  if [ -z "$listfile" ] || [ ! -f "$listfile" ]; then
    echo "Usage: batch_gifs gifs.txt"
    return 1
  fi

  python3 - "$listfile" <<'PY' | while IFS=$'\t' read -r line_no input start_min start_sec end_min end_sec text output; do
import sys, csv

path = sys.argv[1]

with open(path, newline="", encoding="utf-8-sig") as f:
    reader = csv.reader(f, delimiter="\t")
    for i, row in enumerate(reader, 1):
        if not row or not row[0].strip() or row[0].strip().startswith("#"):
            continue

        if len(row) < 7:
            print(f"{i}\tERROR\tmissing fields\t\t\t\t\t")
            continue

        inputfile, sm, ss, em, es = [x.strip() for x in row[:5]]
        outputfile = row[-1].strip()
        text = "\t".join(row[5:-1]).strip()

        print("\t".join([str(i), inputfile, sm, ss, em, es, text, outputfile]))
PY

    if [ "$input" = "ERROR" ]; then
      echo "Skipping line $line_no: $start_min"
      continue
    fi

    if [ ! -f "$input" ]; then
      echo "Skipping line $line_no: input file not found: '$input'"
      continue
    fi

    local temp_gif
    temp_gif="$(mktemp "/tmp/batchgif_${line_no}_XXXXXX.gif")"

    echo "Line $line_no: $input -> $output"
    echo "Text: $text"

    mp4_to_gif "$input" "$start_min" "$start_sec" "$end_min" "$end_sec" "$temp_gif" || {
      echo "Failed creating base GIF on line $line_no"
      rm -f "$temp_gif"
      continue
    }

    text_on_gif "$temp_gif" "$text" "$output" || {
      echo "Failed adding text on line $line_no"
      rm -f "$temp_gif"
      continue
    }

    rm -f "$temp_gif"
    echo "Done: $output"
  done
}