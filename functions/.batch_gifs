function batch_gifs() {
  local listfile="$1"

  if [ -z "$listfile" ] || [ ! -f "$listfile" ]; then
    echo "Usage: batch_gifs gifs.txt"
    return 1
  fi

  local line_no=0

  while IFS= read -r line || [ -n "$line" ]; do
    line_no=$((line_no + 1))
    line="${line%$'\r'}"

    [ -z "$line" ] && continue
    [[ "$line" == \#* ]] && continue

    local input start_min start_sec end_min end_sec text output

    input="$(printf '%s' "$line" | cut -f1)"
    start_min="$(printf '%s' "$line" | cut -f2)"
    start_sec="$(printf '%s' "$line" | cut -f3)"
    end_min="$(printf '%s' "$line" | cut -f4)"
    end_sec="$(printf '%s' "$line" | cut -f5)"
    text="$(printf '%s' "$line" | cut -f6)"
    output="$(printf '%s' "$line" | cut -f7)"

    if [ -z "$input" ] || [ -z "$start_min" ] || [ -z "$start_sec" ] || \
       [ -z "$end_min" ] || [ -z "$end_sec" ] || [ -z "$text" ] || [ -z "$output" ]; then
      echo "Skipping line $line_no: missing fields"
      echo "Parsed:"
      echo "input='$input'"
      echo "start_min='$start_min'"
      echo "start_sec='$start_sec'"
      echo "end_min='$end_min'"
      echo "end_sec='$end_sec'"
      echo "text='$text'"
      echo "output='$output'"
      continue
    fi

    if [ ! -f "$input" ]; then
      echo "Skipping line $line_no: input file not found: '$input'"
      continue
    fi

    local temp_gif
    temp_gif="$(mktemp "/tmp/batchgif_${line_no}_XXXXXX.gif")"

    echo "Line $line_no: $input -> $output"
    echo "Text: $text"

    mp4_to_gif "$input" "$start_min" "$start_sec" "$end_min" "$end_sec" "$temp_gif" </dev/null || {
      echo "Failed creating base GIF on line $line_no"
      rm -f "$temp_gif"
      continue
    }

    text_on_gif "$temp_gif" "$text" "$output" </dev/null || {
      echo "Failed adding text on line $line_no"
      rm -f "$temp_gif"
      continue
    }

    rm -f "$temp_gif"
    echo "Done: $output"
  done < "$listfile"
}