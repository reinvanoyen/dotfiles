function text_on_gif() {
  local input="$1"
  local text="$2"
  local output="${3:-output.gif}"

  if [ -z "$input" ] || [ -z "$text" ]; then
    echo "Usage: text_on_gif input.gif \"caption text\" [output.gif]"
    return 1
  fi

  if ! command -v ffmpeg >/dev/null 2>&1; then
    echo "ffmpeg not found"
    return 1
  fi

  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 not found"
    return 1
  fi

  local font="${FONT:-$HOME/fonts/Ubuntu-Medium.ttf}"

  if [ ! -f "$font" ]; then
    for candidate in \
      "$HOME/fonts/Ubuntu-Medium.ttf" \
      "$HOME/Library/Fonts/Ubuntu-Medium.ttf" \
      "$HOME/Library/Fonts/Ubuntu Medium.ttf" \
      "$HOME/Library/Fonts/Ubuntu-M.ttf" \
      "/Library/Fonts/Ubuntu-Medium.ttf" \
      "/System/Library/Fonts/Supplemental/Arial Bold.ttf"
    do
      if [ -f "$candidate" ]; then
        font="$candidate"
        break
      fi
    done
  fi

  if [ ! -f "$font" ]; then
    echo "Font not found."
    echo "Set it like this:"
    echo 'FONT="$HOME/Library/Fonts/Ubuntu-Medium.ttf" text_on_gif input.gif "text" output.gif'
    return 1
  fi

  font="$(cd "$(dirname "$font")" && pwd)/$(basename "$font")"

  local fftext
  fftext="$(
    TEXT="$text" python3 - <<'PY'
import os, textwrap

text = os.environ["TEXT"].strip()
length = len(text)

if length <= 10:
    size = 52
    width = 1000
elif length <= 18:
    size = 46
    width = 1000
elif length <= 32:
    size = 40
    width = 28
elif length <= 55:
    size = 34
    width = 28
else:
    size = 30
    width = 32

if length <= 32:
    lines = [text]
else:
    lines = textwrap.wrap(text, width=width)
    if len(lines) > 2:
        mid = len(text) // 2
        split = text.rfind(" ", 0, mid)
        if split == -1:
            split = text.find(" ", mid)
        if split != -1:
            lines = [text[:split].strip(), text[split:].strip()]
        else:
            lines = [text]

caption = "\n".join(lines[:2])

caption = caption.replace("\\", "\\\\")
caption = caption.replace(":", "\\:")
caption = caption.replace("'", "\\'")
caption = caption.replace("%", "\\%")

print(size)
print(caption)
PY
  )"

  local fontsize
  local escaped
  fontsize="$(printf '%s\n' "$fftext" | sed -n '1p')"
  escaped="$(printf '%s\n' "$fftext" | sed '1d')"

  ffmpeg -y -i "$input" \
    -filter_complex "[0:v]drawtext=fontfile='$font':text='$escaped':fontsize=$fontsize:fontcolor=white:line_spacing=6:x=(w-text_w)/2:y=h-text_h-28,split[a][b];[a]palettegen=reserve_transparent=0[p];[b][p]paletteuse=dither=bayer" \
    "$output"
}