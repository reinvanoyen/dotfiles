function text_on_gif() {
  local input="$1"
  local text="$2"
  local output="${3:-output.gif}"

  if [ -z "$input" ] || [ -z "$text" ]; then
    echo "Usage: text_on_gif input.gif \"caption text\" [output.gif]"
    return 1
  fi

  command -v ffmpeg >/dev/null 2>&1 || { echo "ffmpeg not found"; return 1; }
  command -v ffprobe >/dev/null 2>&1 || { echo "ffprobe not found"; return 1; }
  command -v python3 >/dev/null 2>&1 || { echo "python3 not found"; return 1; }

  local font="${FONT:-$HOME/fonts/Ubuntu-Medium.ttf}"

  if [ ! -f "$font" ]; then
    for candidate in \
      "$HOME/fonts/Ubuntu-Medium.ttf" \
      "$HOME/Library/Fonts/Ubuntu-Medium.ttf" \
      "$HOME/Library/Fonts/Ubuntu Medium.ttf" \
      "$HOME/Library/Fonts/Ubuntu-M.ttf" \
      "/Library/Fonts/Ubuntu-Medium.ttf" \
      "/System/Library/Fonts/Supplemental/Arial Bold.ttf"
    do
      [ -f "$candidate" ] && font="$candidate" && break
    done
  fi

  if [ ! -f "$font" ]; then
    echo "Font not found. Set FONT=/path/to/font.ttf"
    return 1
  fi

  font="$(cd "$(dirname "$font")" && pwd)/$(basename "$font")"

  local gif_width
  gif_width="$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of csv=p=0 "$input" | head -n 1)"
  gif_width="${gif_width:-400}"

  local fftext
  fftext="$(
    TEXT="$text" GIF_WIDTH="$gif_width" python3 - <<'PY'
import os, textwrap

text = os.environ["TEXT"].strip()
gif_width = int(os.environ.get("GIF_WIDTH", "400"))

# Tuned for 400px GIFs, but scales if needed
scale = gif_width / 400

length = len(text)

if length <= 10:
    size = int(38 * scale)
    width = 14
elif length <= 18:
    size = int(34 * scale)
    width = 17
elif length <= 32:
    size = int(30 * scale)
    width = 18
elif length <= 55:
    size = int(26 * scale)
    width = 20
else:
    size = int(22 * scale)
    width = 23

size = max(18, size)

# Always wrap when needed. Do not keep 32-char lines unwrapped.
lines = textwrap.wrap(
    text,
    width=width,
    break_long_words=False,
    break_on_hyphens=False
)

# Prefer max 2 lines by balancing around the middle
if len(lines) > 2:
    words = text.split()
    best = None

    for i in range(1, len(words)):
        a = " ".join(words[:i])
        b = " ".join(words[i:])
        score = abs(len(a) - len(b))

        if len(a) <= width + 5 and len(b) <= width + 5:
            if best is None or score < best[0]:
                best = (score, a, b)

    if best:
        lines = [best[1], best[2]]
    else:
        lines = textwrap.wrap(
            text,
            width=width,
            break_long_words=False,
            break_on_hyphens=False
        )[:3]

caption = "\n".join(lines)

print(size)
print(caption)
PY
  )"

  local fontsize
  local caption
  fontsize="$(printf '%s\n' "$fftext" | sed -n '1p')"
  caption="$(printf '%s\n' "$fftext" | sed '1d')"

  local caption_file
  caption_file="$(mktemp -t gifcaption)" || return 1
  printf '%s' "$caption" > "$caption_file"

  ffmpeg -y -i "$input" \
    -filter_complex "[0:v]drawtext=fontfile='$font':textfile=$caption_file:fontsize=$fontsize:fontcolor=white:line_spacing=4:text_align=center:x=(w-text_w)/2:y=h-text_h-14,split[a][b];[a]palettegen=reserve_transparent=0[p];[b][p]paletteuse=dither=bayer" \
    "$output"

  local ffmpeg_result=$?
  rm -f "$caption_file"
  return $ffmpeg_result
}